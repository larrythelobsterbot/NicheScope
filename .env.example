# NicheScope Environment Variables
# Copy to .env and fill in your API keys

# Keepa API (~$21/mo) - Required for Amazon price/rank/stock data
KEEPA_API_KEY=

# Amazon Product Advertising API (Free) - For product search
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_PARTNER_TAG=

# Telegram Bot API (Free) - For alert delivery
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
